# ─── Required for both auth methods ─────────────────────────────────────────

# Your GCP project ID (found on the GCP console home page)
GCP_PROJECT_ID=your-gcp-project-id

# Service account email
GCP_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com


# ─── Vercel: Workload Identity Federation ────────────────────────────────────
# Only needed in Vercel dashboard — not required locally.
# See README "Keyless Auth Setup" for the gcloud setup commands.

GCP_PROJECT_NUMBER=123456789012
GCP_WIF_POOL_ID=vercel-pool
GCP_WIF_PROVIDER_ID=vercel-provider


# ─── Local dev ────────────────────────────────────────────────────────────────
# No keys needed. Just run once:
#   gcloud auth application-default login
# The BigQuery client picks up those credentials automatically.
